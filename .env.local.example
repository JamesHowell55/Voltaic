# Copy this file to .env.local (gitignored) and fill in real values.
# Client-side (VITE_ prefix — bundled into the app, safe to expose; protected by Supabase RLS):
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side only (used inside /api serverless functions — never exposed to the browser):
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
STRIPE_PRICE_LIFETIME=
